# Mobile app environment.
# The active variant (dev/stage/prod) is selected by the npm script (e.g. start:dev, android:prod),
# which sets APP_VARIANT for you — you do NOT need to set it here.

# --- Dev (local Supabase) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
EXPO_PUBLIC_EDITOR_WEBVIEW_URL=
# Test-login button (dev/stage only; ignored in prod)
EXPO_PUBLIC_ENABLE_TEST_AUTH=
EXPO_PUBLIC_TEST_AUTH_EMAIL=
EXPO_PUBLIC_TEST_AUTH_PASSWORD=

# --- Stage ---
EXPO_PUBLIC_SUPABASE_URL_STAGE=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY_STAGE=
EXPO_PUBLIC_STAGE_EDITOR_WEBVIEW_URL=

# --- Prod ---
EXPO_PUBLIC_SUPABASE_URL_PROD=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY_PROD=
# Prod ships a bundled editor WebView, so the public share-link origin cannot be derived and must be set here.
EXPO_PUBLIC_PROD_PUBLIC_WEB_ORIGIN=

# --- Optional overrides (leave unset unless you need them) ---
# Point prod at a remote editor instead of the bundled WebView:
# EXPO_PUBLIC_PROD_EDITOR_WEBVIEW_URL=
# Override the OAuth redirect (defaults to <scheme>://auth/callback):
# EXPO_PUBLIC_OAUTH_REDIRECT_URL=
