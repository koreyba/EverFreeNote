{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["jest"],
    "baseUrl": ".",
    "paths": {
      "@core/*": [
        "../../../core/*"
      ],
      "@ui/mobile/*": [
        "../*"
      ],
      "@/*": [
        "../../../*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
