# Supabase project URL (Settings > API > Project URL)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key — bypasses RLS for local script use only
# NEVER commit .env or use this key in client-side code
# (Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google Gemini API key (aistudio.google.com)
GEMINI_API_KEY=AIza...

# UUID of the user whose notes to index/query
# Find it in Supabase: Authentication > Users
RAG_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
