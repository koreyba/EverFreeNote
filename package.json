{
  "name": "everfreenote",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:unit": "jest --config jest.config.cjs --selectProjects unit-core unit-web --passWithNoTests",
    "test:unit:core": "jest --config jest.config.cjs --selectProjects unit-core",
    "test:integration:core": "jest --config jest.config.cjs --selectProjects integration-core",
    "test:unit:web": "jest --config jest.config.cjs --selectProjects unit-web",
    "type-check": "tsc --noEmit",
    "type-check:tests": "tsc -p tsconfig.tests.json --noEmit",
    "eslint": "eslint . --max-warnings=0",
    "deno-check": "deno check supabase/functions/**/*.ts",
    "validate": "npm run type-check && npm run type-check:tests && npm run eslint && npm run deno-check",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:migrate": "supabase migration up",
    "db:migration:list": "supabase migration list",
    "db:status": "supabase status",
    "db:studio": "supabase studio",
    "db:link-project": "supabase link --project-ref yabcuywqxgjlruuyhwin",
    "functions:deploy": "supabase functions deploy",
    "functions:serve": "supabase functions serve --no-verify-jwt --env-file .env.local",
    "db:init-users": "node scripts/init-test-users.js",
    "perf:generate": "node scripts/generate-test-notes.js",
    "perf:measure": "node scripts/measure-performance.js",
    "perf:test": "node scripts/test-migrations.js",
    "cypress": "cypress open",
    "test:component": "cypress run --component --browser electron --spec 'cypress/component/**/*.cy.{js,jsx,ts,tsx}'",
    "test:component:coverage": "cypress run --component --browser electron --spec 'cypress/component/**/*.cy.{js,jsx,ts,tsx}' --env codeCoverage=true",
    "test:component:watch": "cypress open --component",
    "coverage:component": "nyc report --reporter=html --reporter=text --report-dir=coverage/component",
    "act:list": "act -l",
    "act:build": "act -W .github/workflows/build.yml",
    "act:e2e": "act -W .github/workflows/e2e-tests.yml",
    "act:component": "act -W .github/workflows/component-tests.yml"
  },
