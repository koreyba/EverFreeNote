# Core web app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ENABLE_TEST_AUTH=
NEXT_PUBLIC_TEST_AUTH_EMAIL=
NEXT_PUBLIC_TEST_AUTH_PASSWORD=
NEXT_PUBLIC_SKIP_AUTH_EMAIL=
NEXT_PUBLIC_SKIP_AUTH_PASSWORD=
NEXT_PUBLIC_ENABLE_IMAGE_PROXY=
NEXT_PUBLIC_ASSET_PREFIX=

# Local Supabase tooling
SUPABASE_URL=http://127.0.0.1:54321
# Legacy alias used by local Node scripts (same secret as service role key).
SUPABASE_SERVICE_KEY=

# RAG / AI indexing
# GEMINI_API_KEY is no longer used server-side; users provide their key via Settings → API Keys.
# AI_CREDENTIALS_KEY is the server-side AES-GCM encryption secret for user API keys.
# Generate with: openssl rand -base64 32
AI_CREDENTIALS_KEY=
# Canonical name used by Supabase Edge Functions (preferred in new code/docs).
SUPABASE_SERVICE_ROLE_KEY=

# Test users and scripts
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
TEST_EMAIL=
TEST_PASSWORD=
